GROQ_API_KEY=your_groq_api_key_here
GROQ_CHAT_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=qwen/qwen3.6-27b
GROQ_TRANSCRIPTION_MODEL=whisper-large-v3-turbo
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/prepmatrix
MONGODB_DB=prepmatrix
PORT=8787
NODE_ENV=production
FRONTEND_URL=https://your-app.vercel.app
VITE_API_URL=https://your-backend.onrender.com

# Web Push (keep the private key and scheduler secret server-side only)
VAPID_SUBJECT=mailto:support@yourdomain.com
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
REMINDER_CRON_SECRET=replace_with_at_least_32_random_characters
ENABLE_IN_PROCESS_REMINDERS=true

# Optional comma-separated exact or wildcard push-service hosts for additional browsers
PUSH_ENDPOINT_HOSTS=

# SMTP E-mail Config (Required for Settings Forgot Password OTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-google-app-password

# Or use Resend HTTP API (Recommended for Render free tier to avoid SMTP port blocks)
# RESEND_API_KEY=re_your_resend_api_key_here
# MAIL_FROM=PrepMatrix AI <security@yourdomain.com>
