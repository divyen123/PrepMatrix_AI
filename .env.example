GROQ_API_KEY=your_groq_api_key_here
GROQ_CHAT_MODEL=llama-3.3-70b-versatile
GROQ_TRANSCRIPTION_MODEL=whisper-large-v3-turbo
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/prepmatrix
MONGODB_DB=prepmatrix
PORT=8787
NODE_ENV=production
FRONTEND_URL=https://your-app.vercel.app

# SMTP E-mail Config (Required for Settings Forgot Password OTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-google-app-password

# Or use Resend HTTP API (Recommended for Render free tier to avoid SMTP port blocks)
# RESEND_API_KEY=re_your_resend_api_key_here
